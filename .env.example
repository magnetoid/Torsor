# Local development defaults for the Torsor compose-first foundation

# Runtime
NODE_ENV=development
APP_ENV=development

# Database
POSTGRES_DB=torsor_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Used by local host-run workflows or optional docker-compose.override.yml host bindings
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/torsor_dev

# Redis
# Used by local host-run workflows or optional docker-compose.override.yml host bindings
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# API
# Used internally by containers and optionally on localhost via docker-compose.override.yml
API_PORT=3001
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
DEV_SEED_EMAIL=demo@torsor.local
DEV_SEED_PASSWORD=demo12345

# Comma-separated list of emails auto-promoted to super_admin on login/signup.
SUPER_ADMIN_EMAILS=
# Logging + request limits
LOG_LEVEL=info
JSON_BODY_LIMIT=2mb
DATABASE_POOL_MAX=10
AUTH_RATE_LIMIT=20
API_RATE_LIMIT=300

# Frontend
# Used internally by containers and optionally on localhost via docker-compose.override.yml
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:3001
# Production target app domain: https://app.torsor.dev
CHOKIDAR_USEPOLLING=true

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=5000

# AI providers
GEMINI_API_KEY=

# Supabase-compatible / auth-ready placeholders
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional tooling
# Used only if you choose to bind Adminer locally via docker-compose.override.yml
ADMINER_PORT=8080
