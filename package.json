{
  "name": "torsor-foundation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/api",
    "apps/worker"
  ],
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "build:all": "npm run build && npm run build -w apps/api && npm run build -w apps/worker",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "npm run lint:frontend && npm run lint:api && npm run lint:worker",
    "lint:frontend": "tsc --noEmit",
    "lint:api": "npm run lint -w apps/api",
    "lint:worker": "npm run lint -w apps/worker",
    "test": "vitest run",
    "test:watch": "vitest"
  },
